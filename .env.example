# Copy this to .env and fill in your values
# Get your PAT from: airtable.com → account icon → Developer Hub → Personal Access Tokens
# Required scopes: data.records:read (add schema.bases:read to pull filter options from Airtable)
# Base ID and Table ID: set to your Airtable base and table (no hardcoding in app code)
# Optional – if "Distance from you" doesn’t work (e.g. zip API blocked): get a free key at locationiq.com and set VITE_LOCATIONIQ_KEY for zip→distance

VITE_AIRTABLE_PAT=your_personal_access_token_here
VITE_AIRTABLE_BASE_ID=appKtPJiD3Pex9ai1
VITE_AIRTABLE_TABLE_ID=tblfEZNHgfRwvvVJc
# VITE_LOCATIONIQ_KEY=your_free_locationiq_key